<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jakey Raj Rajpal | Accounting, Audit & Finance Professional</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #00d4ff;
            --secondary: #7c3aed;
            --bg: #0a0a0f;
            --bg-card: #12121a;
            --bg-card2: #1a1a2e;
            --text: #e2e8f0;
            --text-muted: #94a3b8;
            --border: #2a2a3e;
            --gradient: linear-gradient(135deg, #00d4ff, #7c3aed);
        }
        html { scroll-behavior: smooth; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); overflow-x: hidden; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 3px; }
        /* NAV */
        nav {
            position: fixed; top: 0; width: 100%; z-index: 1000;
            padding: 1rem 2rem; display: flex; justify-content: space-between;
            align-items: center; transition: all 0.3s ease;
        }
        nav.scrolled {
            background: rgba(10,10,15,0.95); backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border); padding: 0.75rem 2rem;
        }
        .nav-logo {
            font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; font-weight: 700;
            background: var(--gradient); -webkit-background-clip: text;
            -webkit-text-fill-color: transparent; background-clip: text;
        }
        .nav-links { display: flex; list-style: none; gap: 2rem; }
        .nav-links a {
            color: var(--text-muted); text-decoration: none; font-size: 0.9rem;
            font-weight: 500; transition: color 0.3s; position: relative;
        }
        .nav-links a::after {
            content: ''; position: absolute; bottom: -4px; left: 0;
            width: 0; height: 2px; background: var(--gradient); transition: width 0.3s;
        }
        .nav-links a:hover { color: var(--primary); }
        .nav-links a:hover::after { width: 100%; }
        .hamburger {
            display: none; flex-direction: column; gap: 5px;
            cursor: pointer; background: none; border: none;
        }
        .hamburger span { width: 25px; height: 2px; background: var(--text); transition: all 0.3s; }
        /* HERO */
        #hero {
            min-height: 100vh; display: flex; align-items: center;
            position: relative; overflow: hidden; padding: 0 2rem;
        }
        #hero-canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
        .hero-content {
            position: relative; z-index: 1; max-width: 1200px;
            margin: 0 auto; width: 100%; padding: 6rem 0;
            display: grid; grid-template-columns: 1fr auto; gap: 4rem; align-items: center;
        }
        .hero-text { display: flex; flex-direction: column; }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 0.5rem;
            background: rgba(0,212,255,0.1); border: 1px solid rgba(0,212,255,0.3);
            border-radius: 50px; padding: 0.5rem 1rem; font-size: 0.85rem;
            color: var(--primary); margin-bottom: 1.5rem;
            animation: fadeInUp 0.6s ease forwards;
        }
        .hero-badge span {
            width: 8px; height: 8px; background: var(--primary);
            border-radius: 50%; animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%,100% { opacity:1; transform:scale(1); }
            50% { opacity:0.5; transform:scale(1.3); }
        }
        .hero-name {
            font-family: 'Space Grotesk', sans-serif;
            font-size: clamp(3rem, 8vw, 6rem); font-weight: 900;
            line-height: 1.05; margin-bottom: 1rem;
            animation: fadeInUp 0.7s ease 0.1s both;
        }
        .hero-name span {
            background: var(--gradient); -webkit-background-clip: text;
            -webkit-text-fill-color: transparent; background-clip: text;
        }
        .hero-tagline {
            font-size: clamp(1rem, 2.5vw, 1.4rem); color: var(--text-muted);
            margin-bottom: 2rem; animation: fadeInUp 0.7s ease 0.2s both;
            min-height: 2em;
        }
        .hero-tagline strong { color: var(--text); }
        /* TYPING ANIMATION */
        #typed-text {
            background: var(--gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 700;
        }
        .typing-cursor {
            display: inline-block;
            color: var(--primary);
            font-weight: 300;
            animation: blink 0.8s infinite;
            margin-left: 2px;
            -webkit-text-fill-color: var(--primary);
        }
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }
        .hero-description {
            font-size: 1rem; color: var(--text-muted); max-width: 600px;
            line-height: 1.8; margin-bottom: 2.5rem;
            animation: fadeInUp 0.7s ease 0.3s both;
        }
        .hero-ctas {
            display: flex; gap: 1rem; flex-wrap: wrap;
            animation: fadeInUp 0.7s ease 0.4s both;
        }
        .btn-primary {
            background: var(--gradient); color: white; padding: 0.9rem 2rem;
            border-radius: 8px; text-decoration: none; font-weight: 600;
            font-size: 0.95rem; transition: all 0.3s; border: none; cursor: pointer;
            box-shadow: 0 0 30px rgba(0,212,255,0.3);
        }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 0 50px rgba(0,212,255,0.5); }
        .btn-secondary {
            background: transparent; color: var(--text); padding: 0.9rem 2rem;
            border-radius: 8px; text-decoration: none; font-weight: 600;
            font-size: 0.95rem; transition: all 0.3s; border: 1px solid var(--border);
        }
        .btn-secondary:hover { border-color: var(--primary); color: var(--primary); transform: translateY(-2px); }
        .hero-stats {
            display: flex; gap: 3rem; margin-top: 4rem; flex-wrap: wrap;
            animation: fadeInUp 0.7s ease 0.5s both;
        }
        .hero-stat h3 {
            font-family: 'Space Grotesk', sans-serif; font-size: 2.5rem; font-weight: 800;
            background: var(--gradient); -webkit-background-clip: text;
            -webkit-text-fill-color: transparent; background-clip: text;
        }
        .hero-stat p { color: var(--text-muted); font-size: 0.85rem; margin-top: 0.25rem; }
        .scroll-indicator {
            position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
            display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
            color: var(--text-muted); font-size: 0.75rem; animation: bounce 2s infinite;
        }
        @keyframes bounce {
            0%,100% { transform: translateX(-50%) translateY(0); }
            50% { transform: translateX(-50%) translateY(-10px); }
        }
        /* HERO PHOTO */
        .hero-photo-container {
            position: relative; z-index: 1;
            display: flex; align-items: center; justify-content: center;
        }
        .hero-photo-ring {
            width: 320px; height: 320px; border-radius: 50%;
            padding: 4px; background: var(--gradient);
            box-shadow: 0 0 60px rgba(0,212,255,0.3);
            animation: fadeInUp 0.8s ease 0.3s both; flex-shrink: 0;
        }
        .hero-photo {
            width: 100%; height: 100%; border-radius: 50%;
            object-fit: cover; object-position: center top;
            border: 4px solid var(--bg);
        }
        /* SECTIONS */
        section { padding: 6rem 2rem; max-width: 1200px; margin: 0 auto; }
        .full-section {
            background: var(--bg-card); border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }
        .full-section .inner { max-width: 1200px; margin: 0 auto; padding: 6rem 2rem; }
        .section-tag {
            display: inline-flex; align-items: center; gap: 0.5rem;
            color: var(--primary); font-size: 0.8rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem;
        }
        .section-tag::before { content: ''; width: 2rem; height: 2px; background: var(--gradient); }
        .section-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; margin-bottom: 1rem;
        }
        .section-subtitle {
            color: var(--text-muted); font-size: 1.05rem; max-width: 600px;
            line-height: 1.8; margin-bottom: 4rem;
        }
        /* ABOUT */
        .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
        .about-image-container { position: relative; }
        .about-image-box {
            width: 100%; aspect-ratio: 1; border-radius: 20px;
            background: var(--bg-card2); border: 1px solid var(--border);
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; position: relative; overflow: hidden;
        }
        .about-image-box::before {
            content: ''; position: absolute; inset: 0;
            background: var(--gradient); opacity: 0.05;
        }
        .about-image-box .initials {
            font-family: 'Space Grotesk', sans-serif; font-size: 5rem; font-weight: 800;
            background: var(--gradient); -webkit-background-clip: text;
            -webkit-text-fill-color: transparent; background-clip: text; z-index: 1;
        }
        .about-image-box .subtitle-tag { font-size: 0.85rem; color: var(--text-muted); z-index: 1; margin-top: 0.5rem; }
        .floating-badge {
            position: absolute; background: var(--bg-card); border: 1px solid var(--border);
            border-radius: 12px; padding: 0.75rem 1rem; display: flex; align-items: center;
            gap: 0.5rem; font-size: 0.8rem; font-weight: 600;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .floating-badge.top-right { top: -1rem; right: -1rem; color: var(--primary); }
        .floating-badge.bottom-left { bottom: -1rem; left: -1rem; color: #a78bfa; }
        .about-info h3 { font-family: 'Space Grotesk', sans-serif; font-size: 1.1rem; font-weight: 600; margin-bottom: 1rem; color: var(--primary); }
        .about-info p { color: var(--text-muted); line-height: 1.9; margin-bottom: 1.5rem; }
        .about-highlights { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2rem; }
        .highlight-item {
            display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem;
            background: var(--bg-card); border-radius: 8px; border: 1px solid var(--border);
            font-size: 0.85rem; color: var(--text-muted);
        }
        .highlight-item i { color: var(--primary); width: 16px; }
        /* TIMELINE */
        .timeline { position: relative; padding-left: 2rem; }
        .timeline::before {
            content: ''; position: absolute; left: 0; top: 0; bottom: 0;
            width: 2px; background: linear-gradient(to bottom, var(--primary), var(--secondary), transparent);
        }
        .timeline-item {
            position: relative; margin-bottom: 3rem; padding-left: 2rem;
            opacity: 0; transform: translateX(-20px); transition: all 0.6s ease;
        }
        .timeline-item.visible { opacity: 1; transform: translateX(0); }
        .timeline-dot {
            position: absolute; left: -2.45rem; top: 0.5rem;
            width: 14px; height: 14px; border-radius: 50%;
            background: var(--gradient); border: 3px solid var(--bg-card);
            box-shadow: 0 0 15px rgba(0,212,255,0.5);
        }
        .timeline-card {
            background: var(--bg); border: 1px solid var(--border);
            border-radius: 16px; padding: 1.75rem; transition: all 0.3s;
        }
        .timeline-card:hover {
            border-color: rgba(0,212,255,0.3);
            box-shadow: 0 10px 40px rgba(0,0,0,0.3); transform: translateY(-3px);
        }
        .timeline-header {
            display: flex; justify-content: space-between; align-items: flex-start;
            margin-bottom: 0.5rem; flex-wrap: wrap; gap: 1rem;
        }
        .timeline-company { font-family: 'Space Grotesk', sans-serif; font-size: 1.15rem; font-weight: 700; }
        .timeline-period {
            background: rgba(0,212,255,0.1); border: 1px solid rgba(0,212,255,0.2);
            border-radius: 50px; padding: 0.25rem 0.75rem; font-size: 0.75rem;
            color: var(--primary); white-space: nowrap;
        }
        .timeline-role { color: var(--primary); font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; }
        .timeline-location {
            color: var(--text-muted); font-size: 0.8rem; margin-bottom: 1rem;
            display: flex; align-items: center; gap: 0.5rem;
        }
        .timeline-bullets { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
        .timeline-bullets li {
            color: var(--text-muted); font-size: 0.88rem; line-height: 1.6;
            display: flex; gap: 0.75rem;
        }
        .timeline-bullets li::before { content: '►'; color: var(--primary); flex-shrink: 0; font-size: 0.6rem; margin-top: 0.25rem; }
        .timeline-multi-role {
            background: rgba(0,212,255,0.04); border: 1px solid rgba(0,212,255,0.12);
            border-radius: 10px; padding: 1rem; margin-bottom: 1rem;
        }
        .timeline-multi-role:last-child { margin-bottom: 0; }
        .role-header {
            display: flex; justify-content: space-between; align-items: center;
            flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;
        }
        /* SKILLS */
        .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
        .skill-category {
            background: var(--bg-card); border: 1px solid var(--border);
            border-radius: 16px; padding: 2rem; transition: all 0.3s;
            opacity: 0; transform: translateY(20px);
        }
        .skill-category.visible { opacity: 1; transform: translateY(0); }
        .skill-category:hover { border-color: rgba(0,212,255,0.3); }
        .skill-cat-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; }
        .skill-cat-icon {
            width: 42px; height: 42px; border-radius: 10px;
            background: rgba(0,212,255,0.1); display: flex; align-items: center;
            justify-content: center; color: var(--primary); font-size: 1.1rem;
        }
        .skill-cat-title { font-weight: 700; font-size: 1rem; }
        .skill-item { margin-bottom: 1.2rem; }
        .skill-item-header { display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.85rem; }
        .skill-item-header span:first-child { color: var(--text-muted); }
        .skill-item-header span:last-child { color: var(--primary); font-weight: 600; }
        .skill-bar { height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
        .skill-fill { height: 100%; background: var(--gradient); border-radius: 3px; width: 0; transition: width 1.2s ease; }
        .skill-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
        .skill-tag {
            background: rgba(0,212,255,0.08); border: 1px solid rgba(0,212,255,0.15);
            border-radius: 6px; padding: 0.35rem 0.75rem; font-size: 0.78rem;
            color: var(--text-muted); transition: all 0.3s;
        }
        .skill-tag:hover { background: rgba(0,212,255,0.15); color: var(--primary); border-color: rgba(0,212,255,0.4); }
        /* EDUCATION */
        .edu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
        .edu-card {
            background: var(--bg); border: 1px solid var(--border);
            border-radius: 16px; padding: 2rem; transition: all 0.3s;
            position: relative; overflow: hidden;
        }
        .edu-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0;
            height: 3px; background: var(--gradient);
        }
        .edu-card:hover { transform: translateY(-5px); box-shadow: 0 20px 50px rgba(0,0,0,0.3); }
        .edu-icon {
            width: 50px; height: 50px; border-radius: 12px;
            background: rgba(0,212,255,0.1); display: flex; align-items: center;
            justify-content: center; color: var(--primary); font-size: 1.3rem; margin-bottom: 1.25rem;
        }
        .edu-degree { font-weight: 700; font-size: 1rem; margin-bottom: 0.5rem; }
        .edu-institution { color: var(--primary); font-size: 0.85rem; font-weight: 500; margin-bottom: 0.25rem; }
        .edu-location-date { color: var(--text-muted); font-size: 0.8rem; display: flex; align-items: center; gap: 0.5rem; }
        .cert-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 1rem; margin-top: 1.5rem; }
        .cert-badge {
            background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.2);
            border-radius: 10px; padding: 0.75rem 1rem; font-size: 0.82rem;
            color: #a78bfa; display: flex; align-items: center; gap: 0.5rem; transition: all 0.3s;
        }
        .cert-badge:hover { background: rgba(124,58,237,0.2); transform: translateY(-2px); }
        /* LEADERSHIP */
        .leadership-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; }
        .leadership-card {
            background: var(--bg-card); border: 1px solid var(--border);
            border-radius: 16px; padding: 1.5rem; transition: all 0.3s;
        }
        .leadership-card:hover { border-color: rgba(0,212,255,0.3); transform: translateY(-3px); }
        .leadership-icon { font-size: 2rem; margin-bottom: 0.75rem; }
        .leadership-card h4 { font-weight: 700; font-size: 0.95rem; margin-bottom: 0.4rem; }
        .leadership-card p { color: var(--text-muted); font-size: 0.82rem; line-height: 1.6; }
        /* LANGUAGES */
        .lang-grid { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1.5rem; }
        .lang-badge {
            background: var(--bg-card); border: 1px solid var(--border);
            border-radius: 50px; padding: 0.6rem 1.25rem; font-size: 0.85rem;
            display: flex; align-items: center; gap: 0.5rem; transition: all 0.3s;
        }
        .lang-badge:hover { border-color: var(--primary); color: var(--primary); }
        .lang-level {
            font-size: 0.7rem; background: rgba(0,212,255,0.1);
            color: var(--primary); padding: 0.15rem 0.5rem; border-radius: 50px;
        }
        /* VIDEOS */
        .videos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 2rem;
        }
        .video-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
            transition: all 0.3s;
            opacity: 0;
            transform: translateY(20px);
        }
        .video-card.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .video-card:hover {
            border-color: rgba(0,212,255,0.3);
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
            transform: translateY(-5px);
        }
        .video-thumbnail {
            position: relative;
            height: 210px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            /* cursor handled by the <a> tag inside */
        }
        .video-thumb-esg {
            background: linear-gradient(135deg, #0a2a1a, #1a4a2e, #0d3320);
        }
        .video-thumb-sixsigma {
            background: linear-gradient(135deg, #1a0a2e, #2e1a4a, #200d3a);
        }

        /* ── Play-button anchor: fills the entire thumbnail area ── */
        .video-thumb-link {
            position: absolute;
            inset: 0;                   /* top/right/bottom/left: 0 */
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            z-index: 2;                 /* sits above the decorative content */
        }

        .video-thumb-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.3s;
            /* pointer-events: none so the <a> tag receives the click */
            pointer-events: none;
        }
        .video-card:hover .video-thumb-overlay {
            background: rgba(0,0,0,0.5);
        }
        .video-play-btn {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            background: var(--gradient);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.4rem;
            box-shadow: 0 0 30px rgba(0,212,255,0.5);
            transition: all 0.3s;
            padding-left: 5px;
            /* pointer-events: none — the <a> parent handles clicks */
            pointer-events: none;
        }
        .video-card:hover .video-play-btn {
            transform: scale(1.12);
            box-shadow: 0 0 55px rgba(0,212,255,0.8);
        }
        .video-thumb-content {
            position: absolute;
            bottom: 1rem;
            left: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            z-index: 1;
            pointer-events: none;       /* decorative only */
        }
        .video-thumb-icon { font-size: 1.5rem; }
        .video-thumb-label {
            background: rgba(0,0,0,0.6);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50px;
            padding: 0.25rem 0.75rem;
            font-size: 0.75rem;
            color: var(--text-muted);
            backdrop-filter: blur(5px);
        }
        .video-linkedin-badge {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: rgba(10,102,194,0.85);
            border-radius: 8px;
            padding: 0.3rem 0.6rem;
            font-size: 0.75rem;
            color: white;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            backdrop-filter: blur(5px);
            z-index: 1;
            pointer-events: none;       /* decorative only */
        }
        .video-card-body { padding: 1.5rem; }
        .video-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            margin-bottom: 0.85rem;
        }
        .video-tag {
            background: rgba(0,212,255,0.08);
            border: 1px solid rgba(0,212,255,0.18);
            border-radius: 50px;
            padding: 0.2rem 0.65rem;
            font-size: 0.72rem;
            color: var(--primary);
        }
        .video-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
            line-height: 1.45;
        }
        .video-desc {
            color: var(--text-muted);
            font-size: 0.85rem;
            line-height: 1.75;
            margin-bottom: 1.25rem;
